    ('FML-C9-G0', 'MAT-GRAIN-GAOLUATOM', 195.000, 'kg', NULL, NULL, 'SKU_SPECIFIC', '2025-01-01T07:00:00+07:00'::timestamptz),
    ('FML-C9-G0', 'MAT-VEG-CARROT', 35.000, 'kg', NULL, NULL, 'SKU_SPECIFIC', '2025-01-01T07:00:00+07:00'::timestamptz),
    ('FML-C9-G0', 'MAT-VEG-BIDOBI', 33.000, 'kg', NULL, NULL, 'SKU_SPECIFIC', '2025-01-01T07:00:00+07:00'::timestamptz),
    ('FML-C9-G0', 'MAT-VEG-DAUXA', 29.500, 'kg', NULL, NULL, 'SKU_SPECIFIC', '2025-01-01T07:00:00+07:00'::timestamptz),
    ('FML-C9-G0', 'MAT-VEG-NAMKIMCHAM', 18.500, 'kg', NULL, NULL, 'SKU_SPECIFIC', '2025-01-01T07:00:00+07:00'::timestamptz),
    ('FML-C9-G0', 'MAT-HERB-TAOTAU', 4.400, 'kg', NULL, NULL, 'SKU_SPECIFIC', '2025-01-01T07:00:00+07:00'::timestamptz),
    ('FML-C9-G0', 'MAT-VEG-CUCAITRANG', 49.200, 'kg', NULL, NULL, 'SKU_SPECIFIC', '2025-01-01T07:00:00+07:00'::timestamptz),
    ('FML-C9-G0', 'MAT-HERB-RONGBIEN', 7.000, 'kg', NULL, 'kombu/wakame', 'SKU_SPECIFIC', '2025-01-01T07:00:00+07:00'::timestamptz),
