    ('FML-C9-G0', 'MAT-LIQ-NUOCDUA', 55.000, 'lít', NULL, NULL, 'SKU_SPECIFIC', '2025-01-01T07:00:00+07:00'::timestamptz),
    ('FML-C9-G0', 'MAT-SEAS-MUOIRANG', 12.840, 'kg', NULL, NULL, 'SKU_SPECIFIC', '2025-01-01T07:00:00+07:00'::timestamptz),
    ('FML-C9-G0', 'MAT-SEAS-TIEUDEN', 1.320, 'kg', NULL, NULL, 'SKU_SPECIFIC', '2025-01-01T07:00:00+07:00'::timestamptz),
    ('FML-C9-G0', 'MAT-SEAS-TOINUONG', 0.720, 'kg', NULL, NULL, 'SKU_SPECIFIC', '2025-01-01T07:00:00+07:00'::timestamptz),
    ('FML-C9-G0', 'MAT-SEAS-HANHLAKUC', 2.190, 'kg', NULL, NULL, 'SKU_SPECIFIC', '2025-01-01T07:00:00+07:00'::timestamptz),
    ('FML-C9-G0', 'MAT-VEG-RECANHTAY', 1.250, 'kg', NULL, NULL, 'SKU_SPECIFIC', '2025-01-01T07:00:00+07:00'::timestamptz)
), resolved AS (
    SELECT r.id AS recipe_id,
           m.id AS material_id,
           seed.quantity::numeric AS quantity,
           seed.uom_code,
           seed.tolerance::numeric AS tolerance,
           seed.ingredient_note,
           seed.ingredient_section,
           seed.created_at
    FROM seed
    JOIN op_production_recipe r ON r.recipe_code = seed.recipe_code AND r.is_deleted = FALSE
    JOIN op_raw_material m ON m.material_code = seed.material_code AND m.is_deleted = FALSE
)
INSERT INTO op_recipe_ingredient (recipe_id, material_id, quantity, uom_code, tolerance, ingredient_note, ingredient_section, created_at, is_deleted)
SELECT resolved.recipe_id, resolved.material_id, resolved.quantity, resolved.uom_code,
       resolved.tolerance, resolved.ingredient_note, resolved.ingredient_section, resolved.created_at, FALSE
FROM resolved
WHERE NOT EXISTS (
    SELECT 1
    FROM op_recipe_ingredient i
    WHERE i.recipe_id = resolved.recipe_id
      AND i.material_id = resolved.material_id
      AND i.ingredient_section = resolved.ingredient_section
      AND COALESCE(i.ingredient_note, '') = COALESCE(resolved.ingredient_note, '')
      AND i.is_deleted = FALSE
);

COMMIT;
