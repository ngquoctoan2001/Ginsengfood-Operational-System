    ('FML-C9-G1', 'MAT-HERB-GINGNUONG', 0.800, 'kg', NULL, 'Gừng nướng', 'SKU_SPECIFIC', '2026-04-25T16:00:00+07:00'::timestamptz),
    ('FML-C9-G1', 'MAT-GRAIN-GAOLUATOM', 195.000, 'kg', NULL, 'Gạo lúa tôm rửa sạch — nền chính', 'BASE_NUTRITION', '2026-04-25T16:00:00+07:00'::timestamptz),
