    ('FML-C9-G1', 'MAT-VEG-BIDOBI', 33.000, 'kg', NULL, 'Bí đỏ thái hạt lựu', 'BASE_NUTRITION', '2026-04-25T16:00:00+07:00'::timestamptz),
    ('FML-C9-G1', 'MAT-VEG-DAUXA', 29.500, 'kg', NULL, 'Đậu xanh không vỏ', 'BASE_NUTRITION', '2026-04-25T16:00:00+07:00'::timestamptz),
