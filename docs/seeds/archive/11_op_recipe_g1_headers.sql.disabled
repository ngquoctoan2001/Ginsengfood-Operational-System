BEGIN;

WITH seed(recipe_code, recipe_name, sku_code, recipe_status, version_number, recipe_note, created_at) AS (
    VALUES
    ('FML-A1-G1', 'Cháo Sâm – Diêm mạch & Hạt sen (G1)', 'A1/CS/DM/HS', 'ACTIVE', 1, 'G1 — Công thức cập nhật vận hành / sản xuất mẫu. Cơ sở tính: 195 kg gạo = 100%.', '2026-04-25T16:00:00+07:00'::timestamptz),
