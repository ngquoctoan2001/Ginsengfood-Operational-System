    FROM seed
    JOIN ref_sku sku ON sku.sku_code = seed.sku_code AND sku.is_deleted = FALSE
)
INSERT INTO op_production_recipe (recipe_code, recipe_name, sku_id, recipe_status, version_number, recipe_note, created_at, is_deleted)
SELECT resolved.recipe_code, resolved.recipe_name, resolved.sku_id, resolved.recipe_status,
       resolved.version_number, resolved.recipe_note, resolved.created_at, FALSE
FROM resolved
WHERE NOT EXISTS (
    SELECT 1 FROM op_production_recipe r WHERE r.recipe_code = resolved.recipe_code
);

COMMIT;
