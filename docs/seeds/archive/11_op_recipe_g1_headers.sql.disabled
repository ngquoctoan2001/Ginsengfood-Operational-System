    ('FML-C3-G1', 'Cháo Sâm – Nấm đông cô (G1)', 'C3/CS/NAMDONGCO', 'ACTIVE', 1, 'G1 — Phân loại: Vegan.', '2026-04-25T16:00:00+07:00'::timestamptz),
    ('FML-C4-G1', 'Cháo Sâm – Cua biển (G1)', 'C4/CS/CUABIEN', 'ACTIVE', 1, 'G1 — Phân loại: Mặn.', '2026-04-25T16:00:00+07:00'::timestamptz),
    ('FML-C5-G1', 'Cháo Sâm – Cá ngừ (G1)', 'C5/CS/CANGU', 'ACTIVE', 1, 'G1 — Phân loại: Mặn. Táo tàu ở Phần 1 là riêng của SKU này (4.4 kg).', '2026-04-25T16:00:00+07:00'::timestamptz),
    ('FML-C6-G1', 'Cháo Sâm – Tôm & Rong biển (G1)', 'C6/CS/TOM/RONGBIEN', 'ACTIVE', 1, 'G1 — Phân loại: Mặn. Rong biển ở Phần 1 (đặc thù C6) tách biệt với rong biển Phần 3 (nước hầm).', '2026-04-25T16:00:00+07:00'::timestamptz),
    ('FML-C7-G1', 'Cháo Sâm – Thịt gà (G1)', 'C7/CS/THITGA', 'ACTIVE', 1, 'G1 — Phân loại: Mặn.', '2026-04-25T16:00:00+07:00'::timestamptz),
    ('FML-C8-G1', 'Cháo Sâm – Thịt heo (G1)', 'C8/CS/THITHEO', 'ACTIVE', 1, 'G1 — Phân loại: Mặn.', '2026-04-25T16:00:00+07:00'::timestamptz),
    ('FML-C9-G1', 'Cháo Sâm – Thịt bò (G1)', 'C9/CS/THITBO', 'ACTIVE', 1, 'G1 — Phân loại: Mặn.', '2026-04-25T16:00:00+07:00'::timestamptz)
), resolved AS (
    SELECT seed.recipe_code, seed.recipe_name, sku.id AS sku_id, seed.recipe_status,
           seed.version_number, seed.recipe_note, seed.created_at
    FROM seed
    JOIN ref_sku sku ON sku.sku_code = seed.sku_code AND sku.is_deleted = FALSE
)
UPDATE op_production_recipe r
SET recipe_name = resolved.recipe_name,
    sku_id = resolved.sku_id,
    recipe_status = resolved.recipe_status,
    version_number = resolved.version_number,
    recipe_note = resolved.recipe_note,
    updated_at = NOW()
FROM resolved
WHERE r.recipe_code = resolved.recipe_code
  AND r.is_deleted = FALSE;

WITH seed(recipe_code, recipe_name, sku_code, recipe_status, version_number, recipe_note, created_at) AS (
